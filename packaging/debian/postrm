#!/bin/sh
set -e

case "$1" in
    purge)
        # Remove user data on purge (not on simple remove — preserve user data)
        echo "Purging PowerStats. User database at ~/.local/share/powerstats.db is NOT removed."
        echo "Remove it manually if desired: rm -f ~/.local/share/powerstats.db"
    ;;
    remove|upgrade|failed-upgrade|abort-install|abort-upgrade|disappear)
        # Refresh icon and desktop caches
        if command -v gtk-update-icon-cache >/dev/null 2>&1; then
            gtk-update-icon-cache -f -t /usr/share/icons/hicolor || true
        fi
        if command -v update-desktop-database >/dev/null 2>&1; then
            update-desktop-database /usr/share/applications || true
        fi
    ;;
    *)
        echo "postrm called with unknown argument '$1'" >&2
        exit 1
    ;;
esac

#DEBHELPER#
exit 0
